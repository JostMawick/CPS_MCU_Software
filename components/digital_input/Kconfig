menu "Digital Input Configuration"

    config DIGITAL_INPUT_PIN_HANDGUARD_RIGHT
        int "GPIO Pin for Handguard RIGHT"
        default 18
        help
            GPIO pin number connected to the right handguard switch (User Input).

    config DIGITAL_INPUT_PIN_HANDGUARD_LEFT
        int "GPIO Pin for Handguard LEFT"
        default 19
        help
            GPIO pin number connected to the left handguard switch (User Input).

    config DIGITAL_INPUT_PIN_RESET_BTN
        int "GPIO Pin for Reset Button"
        default 21
        help
            GPIO pin number connected to the Reset button (User Input).

    config DIGITAL_INPUT_PIN_LIGHTGATE_START
        int "GPIO Pin for Lightgate START"
        default 22
        help
            GPIO pin number connected to the lightgate (start) sensor output.

    config DIGITAL_INPUT_PIN_LIGHTGATE_END
        int "GPIO Pin for Lightgate END"
        default 23
        help
            GPIO pin number connected to the lightgate (end) sensor output.

    config DIGITAL_INPUT_PIN_EMERGENCY_BTN
        int "GPIO Pin for Emergency Button Monitor"
        default 5
        help
            GPIO pin number monitoring the state of the hardware emergency stop circuit.
            NOTE: This is for software status only, not safety cutoff!

    config DIGITAL_INPUT_PIN_INDUCTIVE_SWITCH
        int "GPIO Pin for Inductive Switch"
        default 34
        help
            GPIO pin number connected to the inductive switch input.
            Input-only pin (GPIO34-39 are input-only on ESP32).
            External pull-down resistor is used (not internal pull-up).

    config DIGITAL_INPUT_TASK_PRIORITY
        int "Digital Input Task Priority"
        default 10
        range 1 24
        help
            FreeRTOS priority for the input processing task.
            Higher number = higher priority. 
            Should be high enough to process inputs quickly, but not starve communication tasks.

    config DIGITAL_INPUT_TASK_STACK_SIZE
        int "Digital Input Task Stack Size"
        default 2048
        help
            Stack size in bytes for the input processing task.
            Adjust if you add heavy processing or large stack variables.

endmenu
